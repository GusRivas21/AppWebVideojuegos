@model AppWeb.Models.Usuario

@{
    ViewData["Title"] = "Editar Usuario";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="glass-panel animate-in">
                <h2 class="mb-4 text-center text-warning"><i class="fas fa-user-edit me-2"></i>EDITAR USUARIO</h2>
                <hr class="border-secondary opacity-25 mb-4" />
                
                <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="Id" />
                    
                    <div class="row g-3">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Nombre" class="form-label small fw-bold text-info">NOMBRE COMPLETO</label>
                            <input asp-for="Nombre" class="form-control bg-dark border-secondary text-white" />
                            <span asp-validation-for="Nombre" class="text-danger small"></span>
                        </div>
                        
                        <div class="col-md-6 mb-3">
                            <label asp-for="Correo" class="form-label small fw-bold text-info">CORREO ELECTRÓNICO</label>
                            <input asp-for="Correo" class="form-control bg-dark border-secondary text-white" />
                            <span asp-validation-for="Correo" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold text-info">NUEVA CONTRASEÑA (OPCIONAL)</label>
                            <input type="password" name="nuevaContrasena" class="form-control bg-dark border-secondary text-white" placeholder="Dejar en blanco para no cambiar" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="IdRol" class="form-label small fw-bold text-info">ROL DE USUARIO</label>
                            <select asp-for="IdRol" class="form-select bg-dark border-secondary text-white" asp-items="ViewBag.IdRol"></select>
                            <span asp-validation-for="IdRol" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-3 mt-4">
                        <button type="submit" class="btn btn-steam-warning w-100 fw-bold py-2 text-dark">
                            <i class="fas fa-sync-alt me-2"></i>ACTUALIZAR DATOS
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary w-100 fw-bold py-2">
                            CANCELAR
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
