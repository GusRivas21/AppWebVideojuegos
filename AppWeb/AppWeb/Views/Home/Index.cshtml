@model IEnumerable<AppWeb.Models.Videojuego>
@{
    ViewData["Title"] = "Videojuegos";
}

<div class="container mt-5">
    <div class="row text-center mb-5">

        <!-- CATEGORÍAS -->
        <div class="col-md-3 mb-3">
            <div class="feature-card">
                <i class="fas fa-gamepad"></i>
                <h5><a asp-controller="VideoJuegos" asp-action="Categoria">Ver Categorías</a></h5>
                <p>Explora por tipo de juego</p>
            </div>
        </div>

        <!-- MÁS VENDIDOS -->
        <div class="col-md-3 mb-3">
            <div class="feature-card">
                <i class="fas fa-fire"></i>
                <h5>Más Vendidos</h5>
                <p>Los juegos más populares</p>
            </div>
        </div>

        <!-- NUEVOS -->
        <div class="col-md-3 mb-3">
            <div class="feature-card">
                <i class="fas fa-star"></i>
                <h5><a asp-controller="VideoJuegos" asp-action="NuevosJuego">NuevosJuegos</a></h5>
                <p>Lo último en la tienda</p>
            </div>
        </div>

        <!-- PROMOCIONES -->
        <div class="col-md-3 mb-3">
            <div class="feature-card">
                <i class="fas fa-tags"></i>
                <h5><a asp-controller="VideoJuegos" asp-action="Promocion">Promociones</a></h5>
                <p>Ofertas especiales</p>
            </div>
        </div>

    </div>


    <h2 class="text-center fw-bold mb-4" style="color: #FFF;"> Videojuegos Disponibles</h2>
    <div class="row g-4">
        @foreach (var juego in Model)
        {
            <div class="col-md-6 col-lg-4 col-xl-3">
                <div class="card game-card h-100">

                    <!-- 🔴 BADGE SUPERIOR -->
                    <span class="position-absolute top-0 start-0 badge rounded-pill bg-danger m-2">
                        +@juego.Edad
                    </span>

                    @if (juego.Promocion)
                    {
                        <div class="badge-promo bg-success text-white px-2 py-1 rounded" style="position: absolute; top: 10px; right: 10px; z-index: 10;">
                            <i class="fas fa-tag"></i> ¡OFERTA!
                        </div>
                    }

                    <!-- ❤️ FAVORITO -->
                    <div class="favorite">
                        <i class="fa-regular fa-heart"></i>
                    </div>

                    <!-- IMAGEN -->
                    <img src="@juego.imagen"
                         class="card-img-top game-img" />

                    <div class="card-body d-flex flex-column">

                        <!-- TÍTULO -->
                        <h5 class="card-title fw-bold">
                            @juego.Titulo
                        </h5>

                        <!-- PRECIO -->
                        <h4 class="price mt-2">
                            $@juego.Precio
                        </h4>

                        <!-- CATEGORÍA -->
                        <div class="d-flex align-items-center mt-auto">
                            <i class="fa-solid fa-gamepad me-2 text-warning"></i>
                            <span class="text-muted">@juego.idcategoria</span>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>