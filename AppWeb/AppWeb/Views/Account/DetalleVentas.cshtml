@{
    Layout = null;
    var usuario = Context.Session.GetString("usuario");
}

@model List<VentaViewModel>

<form action="/" method="get">
    <input type="date" name="desde" value="@ViewBag.Desde?.ToString("yyyy-MM-dd")" />
    <input type="date" name="hasta" value="@ViewBag.Hasta?.ToString("yyyy-MM-dd")" />
    <button type="submit">Filtrar</button>
</form>

<table class="table">
    <thead>
        <tr>
            <th>Usuario</th>
            <th>VideoJuegoId</th>
            <th>Titulo</th>
            <th>Cantidad</th>
            <th>Total</th>
            <th>Estado</th>
            <th>Fecha</th>
            <th>Codigo</th>
            
        </tr>
    </thead>
    <tbody>
        @foreach (var venta in Model)
        {
            <tr>
                <td>@venta.UsuarioId</td>
                <td>@venta.VideoJuegosId</td>
                <td>@venta.Titulo</td>
                <td>@venta.Cantidad</td>
                <td>@venta.Total</td>
                <td>@venta.EstadoCompra</td>
                <td>@venta.FechaHoraTransaccion</td>
                <td>@venta.CodigoTransaccion</td>
            </tr>
        }
    </tbody>

    <div>
        @for (int i = 1; i<= ViewBag.TotalPages; i++)
        {
            <a href="?pagina=@i&desde=@ViewBag.Desde&hasta=@ViewBag.Hasta">
                @i
             </a>
        }
    </div>