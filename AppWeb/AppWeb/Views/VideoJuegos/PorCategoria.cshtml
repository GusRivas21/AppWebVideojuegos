@model IEnumerable<AppWeb.Models.Videojuego>

@{
    ViewData["Title"] = "Videojuegos por Categoría";
}

<div class="glass-panel mt-4 animate-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">
            <i class="fas fa-filter me-2 text-info"></i>
            @(ViewBag.CategoriaSeleccionada != null && ViewBag.CategoriaSeleccionada != 0 
                ? $"JUEGOS DE {ViewBag.NombreCategoriaSeleccionada?.ToUpper()}" 
                : "TODOS LOS VIDEOJUEGOS")
        </h2>
        
        <div class="dropdown">
            <button class="btn btn-accent dropdown-toggle fw-bold" type="button" id="filterDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                FILTRAR POR CATEGORÍA
            </button>
            <ul class="dropdown-menu dropdown-menu-dark" aria-labelledby="filterDropdown">
                <li><a class="dropdown-item" asp-action="Categoria" asp-route-Categoria="0">Todas</a></li>
                @foreach (var cat in ViewBag.TodasLasCategorias as IEnumerable<AppWeb.Models.Categoria>)
                {
                    <li><a class="dropdown-item" asp-action="Categoria" asp-route-Categoria="@cat.idcategoria">@cat.categoria</a></li>
                }
            </ul>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-gamepad fa-3x text-muted mb-3"></i>
            <p class="text-muted">No se encontraron juegos en esta categoría.</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
            @foreach (var juego in Model)
            {
                <div class="col">
                    <div class="game-card">
                        <img src="@juego.imagen" class="game-img" alt="@juego.Titulo">
                        <div class="card-body">
                            <h5 class="card-title text-white">@juego.Titulo</h5>
                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <span class="price">$@juego.Precio</span>
                                <span class="badge-top">+@juego.Edad</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
