@model IEnumerable<AppWeb.Models.Videojuego>
@{
    ViewData["Title"] = "Videojuegos";
}

<div class="container py-4">
    <!-- CATEGORÍAS RÁPIDAS -->
    <div class="row g-3 mb-5">
        <div class="col-md-3">
            <div class="feature-card h-100">
                <i class="fas fa-gamepad"></i>
                <h5><a asp-controller="VideoJuegos" asp-action="Categoria">Categorías</a></h5>
                <p class="small text-muted mb-0">Explora por género</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="feature-card h-100">
                <i class="fas fa-fire"></i>
                <h5>Más Vendidos</h5>
                <p class="small text-muted mb-0">Lo que todos juegan</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="feature-card h-100">
                <i class="fas fa-star"></i>
                <h5><a asp-controller="VideoJuegos" asp-action="NuevosJuego">Novedades</a></h5>
                <p class="small text-muted mb-0">Recién llegados</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="feature-card h-100">
                <i class="fas fa-tags"></i>
                <h5><a asp-controller="VideoJuegos" asp-action="Promocion">Ofertas</a></h5>
                <p class="small text-muted mb-0">Precios increíbles</p>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold mb-0">VIDEOJUEGOS DESTACADOS</h3>
        <hr class="flex-grow-1 ms-4 opacity-25" />
    </div>

    <div class="row g-4">
        @foreach (var juego in Model)
        {
            <div class="col-6 col-md-4 col-lg-3">
                <div class="game-card shadow">
                    <div class="position-relative">
                        <img src="@juego.imagen" class="game-img" alt="@juego.Titulo" />
                        
                        @if (juego.Promocion)
                        {
                            <span class="badge-promo position-absolute bottom-0 start-0 m-2">
                                -% OFF
                            </span>
                        }
                        
                        <span class="badge-top position-absolute top-0 end-0 m-2">
                            +@juego.Edad
                        </span>
                    </div>

                    <div class="card-body">
                        <h5 class="card-title" title="@juego.Titulo">@juego.Titulo</h5>
                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <span class="price">$@juego.Precio</span>
                            <button class="btn btn-steam-green btn-sm">
                                <i class="fas fa-cart-plus"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>