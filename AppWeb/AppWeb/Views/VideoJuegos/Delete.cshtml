@model AppWeb.Models.Videojuego
@{
    ViewData["Title"] = "Eliminar Videojuego";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="glass-panel border-danger shadow-lg animate__animated animate__headShake">
                <div class="text-center mb-4">
                    <i class="fas fa-exclamation-triangle fa-4x text-danger mb-3"></i>
                    <h3 class="fw-bold text-white">¿CONFIRMAR ELIMINACIÓN?</h3>
                    <p class="text-muted">Esta acción es permanente y no se puede deshacer.</p>
                </div>

                <div class="bg-dark bg-opacity-50 p-4 rounded border border-secondary mb-4">
                    <div class="row align-items-center">
                        <div class="col-4">
                            <img src="@Model.imagen" class="img-fluid rounded" alt="@Model.Titulo" />
                        </div>
                        <div class="col-8">
                            <h5 class="fw-bold text-white mb-1">@Model.Titulo</h5>
                            <p class="price mb-0">$@Model.Precio</p>
                            <span class="badge bg-secondary small">ID: @Model.Id</span>
                        </div>
                    </div>
                </div>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-steam-danger py-3 fw-bold">
                            <i class="fas fa-trash-alt me-2"></i>ELIMINAR DEFINITIVAMENTE
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary py-2">
                            CANCELAR Y VOLVER
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>