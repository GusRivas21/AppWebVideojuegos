@model ErrorViewModel
@{
    ViewData["Title"] = "Error de Sistema";
}

<div class="container py-5 text-center">
    <div class="glass-panel border-danger shadow-lg py-5 animate__animated animate__shakeX">
        <i class="fas fa-bug fa-5x text-danger mb-4 opacity-50"></i>
        <h1 class="fw-bold text-white mb-3">¡OH NO! ALGO SALIÓ MAL</h1>
        <h4 class="text-muted mb-4">Parece que hubo un error al procesar tu solicitud en la red.</h4>

        @if (Model.ShowRequestId)
        {
            <div class="bg-dark bg-opacity-50 p-3 rounded mb-4 d-inline-block">
                <span class="text-info small fw-bold">ID DE SOLICITUD:</span>
                <code class="text-white ms-2">@Model.RequestId</code>
            </div>
        }

        <div class="mt-4">
            <p class="text-muted small">Nuestros técnicos gamer ya están trabajando en restaurar la conexión.</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-accent px-5 fw-bold mt-3">VOLVER AL INICIO</a>
        </div>
    </div>
</div>
