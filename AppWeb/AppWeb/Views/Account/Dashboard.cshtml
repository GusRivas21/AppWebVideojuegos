@{
    Layout = null;
    var usuario = Context.Session.GetString("usuario");
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Dashboard</title>

    <script src="https://code.highcharts.com/highcharts.js"></script>
    <script src="https://code.highcharts.com/modules/exporting.js"></script>
    <script src="https://code.highcharts.com/modules/export-data.js"></script>
    <script src="https://code.highcharts.com/modules/accessibility.js"></script>
    <script src="https://code.highcharts.com/themes/adaptive.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.js" integrity="sha256-eKhayi8LEQwp4NKxN+CfCh+3qOVUtJn3QNZ0TciWLP4=" crossorigin="anonymous"></script>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
            body {
                background-color: #f5f7fb;
            }

            .navbar-custom {
                background: linear-gradient(90deg, #1e3c72, #2a5298);
            }

            .navbar-brand {
                font-weight: bold;
                color: white !important;
            }

            .user-info {
                color: white;
                font-weight: 500;
            }

            .btn-logout {
                border-radius: 10px;
            }

            .dashboard-container {
                padding: 30px;
            }

            .card-placeholder {
                height: 250px;
                border-radius: 15px;
                border: 2px dashed #ccc;
                display: flex;
                align-items: center;
                justify-content: center;
                color: #999;
                font-weight: 500;
                background: white;
            }

            .welcome-box {
                background: white;
                padding: 20px;
                border-radius: 15px;
                margin-bottom: 20px;
                box-shadow: 0 5px 15px rgba(0,0,0,0.05);
            }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-custom px-4">
        <a class="navbar-brand" href="#">Administración de sistema</a>

        <div class="ms-auto d-flex align-items-center gap-3">
            <span class="user-info">
                👤 @usuario
            </span>

            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="btn btn-light btn-sm btn-logout" asp-controller="Home" asp-action="Index">Inicio</a>
                </li>

                <li class="nav-item">
                    <a class="btn btn-light btn-sm btn-logout" asp-controller="Account" asp-action="DetalleVentas">Detalle Ventas</a>
                </li>
            </ul>

            <a asp-controller="Account" asp-action="Logout" class="btn btn-light btn-sm btn-logout">
                Cerrar Sesión
            </a>
        </div>
    </nav>
    <div class="dashboard-container">

      
        <div class="welcome-box">
            <h4>Bienvenido, @usuario 👋</h4>
            <p class="text-muted mb-0">
                Este es tu panel principal. Aquí podrás visualizar estadísticas y gestionar el sistema.
            </p>
        </div>

        <div class="row g-4">
            <div class="col-md-6">
                <select id="filtroCategoria" class="form-select">
                    <option value="">Todas las Categorías</option>
            
                    @if (ViewBag.ListaCategorias != null)
                    {
                        foreach (var cat in ViewBag.ListaCategorias)
                        {
                            <option value="@cat.categoria">@cat.categoria</option>
                        }
                    }
                </select>
                @* Grafica de Juegos por Categoria *@
                <div id="container"></div>
            </div>
        </div>
        
    </div>

</body>

<script>
    $(document).ready(function() {
        cargarGrafica();
    });

    function cargarGrafica(categoriaFiltro = "") {
        $.get('/Account/ObtenerDatos', { categoria: categoriaFiltro }, function(data) {
            

            var categorias = data.map(x => x.categoria);
            var totales = data.map(x => x.total);

            Highcharts.chart('container', {
                chart: {
                    type: 'column'
                },
                title: {
                    text: 'Juegos por Categoria'
                },
                xAxis: {
                    categories: categorias
                },
                yAxis: {
                    title: {
                        text: 'Total de Juegos'
                    }
                },
                series: [{
                    name: 'Juegos',
                    data: totales
                }]
            });
        });
    }

    $('#filtroCategoria').change(function() {
        cargarGrafica($(this).val());
    });
</script>

</html>