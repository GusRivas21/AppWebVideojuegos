@model AppWeb.Models.Videojuego

@{
    ViewData["Title"] = "Confirmar Adquisición";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="glass-panel animate__animated animate__fadeIn">
                <div class="row g-0">
                    <div class="col-md-5">
                        <img src="@Model.imagen" class="img-fluid rounded-start h-100 object-fit-cover" alt="@Model.Titulo" style="min-height: 300px;">
                    </div>
                    <div class="col-md-7">
                        <div class="card-body p-4">
                            <h2 class="fw-bold text-info mb-1">@Model.Titulo.ToUpper()</h2>
                            <p class="text-muted mb-4">@Model.Descripcion</p>
                            
                            <div class="d-flex align-items-center mb-4">
                                <span class="badge bg-secondary me-2">+@Model.Edad AÑOS</span>
                                <span class="badge bg-primary">@Model.Categoria?.categoria</span>
                            </div>

                            <h3 class="fw-bold text-white mb-4">PRECIO: <span class="text-success">$@Model.Precio</span></h3>

                            <form asp-action="Comprar" method="post">
                                <input type="hidden" name="videojuegoId" value="@Model.Id" />
                                
                                <div class="mb-4">
                                    <label class="form-label text-muted small text-uppercase fw-bold">Cantidad</label>
                                    <input type="number" name="cantidad" value="1" min="1" max="10" class="form-control bg-dark border-secondary text-white w-25" id="inputCantidad" /> @* limite de compra *@
                                </div>

                                <div class="d-flex justify-content-between align-items-center pt-3 border-top border-secondary">
                                    <h4 class="mb-0">TOTAL: <span class="text-success" id="totalCompra">$@Model.Precio</span></h4>
                                    <div>
                                        <a asp-action="Index" class="btn btn-outline-secondary me-2">CANCELAR</a>
                                        <button type="submit" class="btn btn-accent px-4 fw-bold">
                                            <i class="fas fa-check me-2"></i>CONFIRMAR COMPRA
                                        </button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            const precio = @Model.Precio;
            $('#inputCantidad').on('input', function() {
                let cant = $(this).val();
                if (cant < 1) cant = 1;
                let total = (precio * cant).toFixed(2);
                $('#totalCompra').text('$' + total);
            });
        });
    </script>
}