@model AppWeb.Models.Videojuego
@{
    ViewData["Title"] = "Editar Videojuego";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="glass-panel shadow-lg animate__animated animate__fadeIn">
                <div class="mb-4 border-bottom border-secondary pb-3">
                    <h3 class="fw-bold mb-0 text-warning"><i class="fas fa-edit me-2"></i>MODIFICAR TÍTULO</h3>
                    <p class="text-muted small mb-0">Actualiza los detalles de <strong>@Model.Titulo</strong></p>
                </div>

                <form asp-action="Edit" enctype="multipart/form-data">
                    <input type="hidden" asp-for="Id" />
                    
                    <div class="row">
                        <div class="col-md-8 mb-3">
                            <label class="form-label small fw-bold text-info">TÍTULO DEL JUEGO</label>
                            <input asp-for="Titulo" class="form-control bg-dark border-secondary text-white" />
                            <span asp-validation-for="Titulo" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label small fw-bold text-info">PRECIO ($)</label>
                            <input asp-for="Precio" class="form-control bg-dark border-secondary text-white" />
                            <span asp-validation-for="Precio" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold text-info">CATEGORÍA</label>
                            <select asp-for="idcategoria" class="form-select bg-dark border-secondary text-white" asp-items="ViewBag.idcategoria">
                                <option value="">-- SELECCIONAR --</option>
                            </select>
                            <span asp-validation-for="idcategoria" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold text-info">EDAD RECOMENDADA</label>
                            <input asp-for="Edad" type="number" class="form-control bg-dark border-secondary text-white" />
                            <span asp-validation-for="Edad" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-info">DESCRIPCIÓN</label>
                        <textarea asp-for="Descripcion" class="form-control bg-dark border-secondary text-white" rows="4"></textarea>
                    </div>

                    <div class="row mb-4 align-items-center">
                        <div class="col-md-4 text-center">
                            <label class="form-label small fw-bold text-muted d-block mb-2">PORTADA ACTUAL</label>
                            <img src="@Model.imagen" class="img-fluid rounded border border-secondary" style="max-height: 150px; object-fit: cover;" />
                        </div>
                        <div class="col-md-8">
                            <label class="form-label small fw-bold text-info">ACTUALIZAR IMAGEN</label>
                            <input type="file" name="archivoImagen" class="form-control bg-dark border-secondary text-white" />
                            <div class="form-text text-muted smaller">Deja en blanco para conservar la imagen actual.</div>
                        </div>
                    </div>

                    <div class="form-check mb-4 p-3 bg-dark bg-opacity-25 rounded border border-secondary border-opacity-25">
                        <input asp-for="Promocion" type="checkbox" class="form-check-input ms-0 me-2" id="checkPromoEdit" />
                        <label class="form-check-label text-warning small fw-bold" for="checkPromoEdit">
                            ¿ACTIVAR PROMOCIÓN / OFERTA ESPECIAL?
                        </label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-steam-warning px-4 py-2 fw-bold">
                            <i class="fas fa-sync-alt me-2"></i>ACTUALIZAR CAMBIOS
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2">
                            CANCELAR
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
