@model IEnumerable<AppWeb.Models.Videojuego>
@{
    ViewData["Title"] = "Ofertas Especiales";
}

<div class="container py-4">
    <div class="text-center mb-5 animate__animated animate__fadeIn">
        <h2 class="fw-bold text-white mb-2"><i class="fas fa-tags text-success me-3"></i>OFERTAS ESPECIALES</h2>
        <p class="text-muted">Aprovecha los mejores descuentos por tiempo limitado</p>
    </div>

    <div class="d-flex justify-content-center flex-wrap gap-3 mb-5">
        <a asp-controller="VideoJuegos" asp-action="Categoria" class="btn btn-outline-secondary rounded-pill px-4 fw-bold small">
            <i class="fas fa-list me-2"></i>CATEGORÍAS
        </a>
        <a asp-controller="VideoJuegos" asp-action="NuevosJuego" class="btn btn-outline-info rounded-pill px-4 fw-bold small">
            <i class="fas fa-star me-2"></i>NOVEDADES
        </a>
    </div>

    <div class="row g-4">
        @foreach (var juego in Model)
        {
            <div class="col-6 col-md-4 col-lg-3">
                <div class="game-card shadow">
                    <div class="position-relative">
                        <img src="@juego.imagen" class="game-img" alt="@juego.Titulo" />
                        <span class="badge-promo position-absolute bottom-0 start-0 m-2">
                            -% OFF
                        </span>
                        <span class="badge-top position-absolute top-0 end-0 m-2">
                            +@juego.Edad
                        </span>
                    </div>

                    <div class="card-body">
                        <h5 class="card-title" title="@juego.Titulo">@juego.Titulo</h5>
                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <span class="price">$@juego.Precio</span>
                            <form asp-controller="Cliente" asp-action="Comprar" method="post">
                                <input type="hidden" name="videojuegoId" value="@juego.Id" />
                                <button type="submit" class="btn btn-steam-green btn-sm">
                                    <i class="fas fa-cart-plus"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
