@model AppWeb.Models.Videojuego

<h2>Crear VideoJuegos</h2>

<form asp-action="Create" method="post" enctype="multipart/form-data">
    <div>
        <label>Titulo</label>
        <input asp-for="Titulo" class="form-control" />
        <span asp-validation-for="Titulo"></span>
    </div>

    <div>
        <label>Precio</label>
        <input asp-for="Precio" class="form-control" />
        <div asp-validation-summary="All" class="text-danger"></div>
        <span asp-validation-for="Precio"></span>
    </div>

    @* <div>
        <label>Categoria</label>
        <input asp-for="idcategoria" class="form-control" />
        <span asp-validation-for="idcategoria"></span>
    </div> *@

    <div class="form-group">
        <label asp-for="idcategoria" class="control-label">Categoría</label>
        <select asp-for="idcategoria" class="form-control" asp-items="ViewBag.idcategoria">
            <option value="">-- Seleccione una Categoría --</option>
        </select>
        <span asp-validation-for="idcategoria" class="text-danger"></span>
    </div>

    <div class="mt-3">
        <label>Clasificación de Edad</label>
        <input asp-for="Edad" type="number" class="form-control" placeholder="Indique la edad mínima" />
        <span asp-validation-for="Edad" class="text-danger"></span>
    </div>

    <div class="form-check mt-3 mb-3">
        <input asp-for="Promocion" type="checkbox" class="form-check-input" id="checkPromo" />
        <label class="form-check-label" for="checkPromo">
            ¿Este juego está en Promoción?
        </label>
    </div>

    <div>
        <label>Descripción</label>
        <textarea asp-for="Descripcion" class="form-control"></textarea>
    </div>

    <div>
        <label>Imagen</label>
        <input type="file" name="archivoImagen" class="form-control"/>
    </div>

    <button type="submit" class="btn btn-primary">Guardar</button>
</form>

