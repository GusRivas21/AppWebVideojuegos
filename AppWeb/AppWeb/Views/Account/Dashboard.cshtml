@model dynamic
@{
    ViewData["Title"] = "Dashboard de Administración";
    var usuario = Context.Session.GetString("usuario");
}

<div class="container py-4">
    <div class="glass-panel mb-4 animate__animated animate__fadeIn">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h3 class="fw-bold mb-1 text-info">BIENVENIDO, @usuario.ToUpper()</h3>
                <p class="text-muted small mb-0">Panel de control y estadísticas globales del sistema</p>
            </div>
            <div class="text-end">
                <i class="fas fa-chart-line fa-3x text-info opacity-25"></i>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="glass-panel h-100">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold text-uppercase small letter-spacing-1 mb-0">Distribución de Videojuegos</h5>
                    <div style="width: 250px;">
                        <select id="filtroCategoria" class="form-select form-select-sm bg-dark border-secondary text-white">
                            <option value="">TODAS LAS CATEGORÍAS</option>
                            @if (ViewBag.ListaCategorias != null)
                            {
                                foreach (var cat in ViewBag.ListaCategorias)
                                {
                                    <option value="@cat.categoria">@cat.categoria.ToUpper()</option>
                                }
                            }
                        </select>
                    </div>
                </div>
                
                <div id="container" style="height: 400px; width: 100%;"></div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="row g-4 h-100">
                <div class="col-12">
                    <div class="feature-card h-100 d-flex flex-column justify-content-center">
                        <i class="fas fa-gamepad mb-2"></i>
                        <h2 class="fw-bold text-white mb-0">@ViewBag.TotalJuegos</h2>
                        <p class="text-muted small text-uppercase fw-bold">Juegos en Catálogo</p>
                    </div>
                </div>
                <div class="col-12">
                    <div class="feature-card h-100 d-flex flex-column justify-content-center" style="border-left: 4px solid var(--steam-green);">
                        <i class="fas fa-shopping-cart mb-2 text-success"></i>
                        <h2 class="fw-bold text-white mb-0">@ViewBag.TotalVentas</h2>
                        <p class="text-muted small text-uppercase fw-bold">Ventas Totales</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="row g-4 mt-2">
        <div class="col-lg-4">
            <div class="glass-panel h-100">
                <h5 class="fw-bold text-uppercase small letter-spacing-1 mb-4">Clasificación por Edad</h5>
                <div id="graficaClasificacion" style="height: 300px; width: 100%;"></div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="glass-panel h-100">
                <h5 class="fw-bold text-uppercase small letter-spacing-1 mb-4">Juegos en Promoción</h5>
                <div id="graficaPromocion" style="height: 300px; width: 100%;"></div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="glass-panel h-100">
                <h5 class="fw-bold text-uppercase small letter-spacing-1 mb-4">Registros de Usuarios</h5>
                <div id="graficaRegistros" style="height: 300px; width: 100%;"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.highcharts.com/highcharts.js"></script>
    <script src="https://code.highcharts.com/modules/exporting.js"></script>
    <script src="https://code.highcharts.com/themes/dark-unica.js"></script>

    <script>
        $(document).ready(function() {
            cargarGrafica();
            cargarGraficaClasificacion();
            cargarGraficaPromocion();
            cargarGraficaRegistros();
        });

        function cargarGrafica(categoriaFiltro = "") {
            $.get('/Account/ObtenerDatos', { categoria: categoriaFiltro }, function(data) {
                var categorias = data.map(x => x.categoria);
                var totales = data.map(x => x.total);

                Highcharts.chart('container', {
                    chart: {
                        type: 'column',
                        backgroundColor: 'transparent'
                    },
                    title: { text: null },
                    xAxis: {
                        categories: categorias,
                        gridLineColor: 'rgba(255,255,255,0.05)'
                    },
                    yAxis: {
                        title: { text: 'CANTIDAD DE TÍTULOS' },
                        gridLineColor: 'rgba(255,255,255,0.05)'
                    },
                    legend: { enabled: false },
                    tooltip: {
                        backgroundColor: '#1b2838',
                        style: { color: '#ffffff' }
                    },
                    plotOptions: {
                        column: {
                            borderRadius: 4,
                            color: '#66c0f4'
                        }
                    },
                    series: [{
                        name: 'Videojuegos',
                        data: totales
                    }]
                });
            });
        }

        function cargarGraficaClasificacion() {
            $.get('/Account/ObtenerDatosClasificacion', function(data) {
                var categorias = data.map(x => x.clasificacion);
                var totales = data.map(x => x.total);

                Highcharts.chart('graficaClasificacion', {
                    chart: {
                        type: 'bar',
                        backgroundColor: 'transparent'
                    },
                    title: { text: null },
                    xAxis: {
                        categories: categorias,
                        gridLineColor: 'rgba(255,255,255,0.05)'
                    },
                    yAxis: {
                        title: { text: 'CANTIDAD' },
                        gridLineColor: 'rgba(255,255,255,0.05)'
                    },
                    legend: { enabled: false },
                    plotOptions: {
                        bar: {
                            borderRadius: 4,
                            color: '#c7d5e0'
                        }
                    },
                    series: [{
                        name: 'Juegos',
                        data: totales
                    }]
                });
            });
        }

        function cargarGraficaPromocion() {
            $.get('/Account/ObtenerDatosPromocion', function(data) {
                var pieData = data.map(x => ({ name: x.estado, y: x.total }));

                Highcharts.chart('graficaPromocion', {
                    chart: {
                        type: 'pie',
                        backgroundColor: 'transparent'
                    },
                    title: { text: null },
                    tooltip: {
                        pointFormat: '{series.name}: <b>{point.percentage:.1f}%</b>'
                    },
                    plotOptions: {
                        pie: {
                            allowPointSelect: true,
                            cursor: 'pointer',
                            dataLabels: {
                                enabled: true,
                                format: '<b>{point.name}</b>: {point.y}',
                                style: { color: 'white' }
                            },
                            colors: ['#5c7e10', '#a34c31']
                        }
                    },
                    series: [{
                        name: 'Porcentaje',
                        colorByPoint: true,
                        data: pieData
                    }]
                });
            });
        }

        function cargarGraficaRegistros() {
            $.get('/Account/ObtenerDatosRegistros', function(data) {
                console.log("Datos de registros:", data);
                var meses = data.map(x => x.mes);
                var totales = data.map(x => x.total);

                Highcharts.chart('graficaRegistros', {
                    chart: {
                        type: 'area',
                        backgroundColor: 'transparent'
                    },
                    title: { text: null },
                    xAxis: {
                        categories: meses,
                        gridLineColor: 'rgba(255,255,255,0.05)'
                    },
                    yAxis: {
                        title: { text: 'NUEVOS USUARIOS' },
                        gridLineColor: 'rgba(255,255,255,0.05)'
                    },
                    plotOptions: {
                        area: {
                            marker: { radius: 4 },
                            lineWidth: 2,
                            states: { hover: { lineWidth: 3 } }
                        }
                    },
                    series: [{
                        name: 'Usuarios',
                        data: totales,
                        color: '#66c0f4',
                        fillOpacity: 0.3
                    }]
                });
            });
        }

        $('#filtroCategoria').change(function() {
            cargarGrafica($(this).val());
        });
    </script>
}