@model AppWeb.Models.Categoria

@{
    ViewData["Title"] = "Editar Categoría";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="glass-panel animate-in">
                <h2 class="mb-4 text-center text-warning"><i class="fas fa-edit me-2"></i>EDITAR CATEGORÍA</h2>
                <hr class="border-secondary opacity-25 mb-4" />
                
                <form asp-action="Edit" asp-route-id="@Model.idcategoria" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="idcategoria" />
    
                    <div class="mb-4">
                        <label asp-for="categoria" class="form-label small fw-bold text-info">NOMBRE DE LA CATEGORÍA</label>
                        @* Agregamos un value fallback por si el modelo llega nulo, evitando el error de consola *@
                        <input asp-for="categoria" value="@(Model?.categoria ?? "")" class="form-control bg-dark border-secondary text-white py-2" />
                        <span asp-validation-for="categoria" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-3">
                        @* QUITAMOS el asp-action de aquí *@
                        <button type="submit" class="btn btn-steam-warning w-100 fw-bold py-2 text-dark">
                            <i class="fas fa-sync-alt me-2"></i>ACTUALIZAR
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary w-100 fw-bold py-2">
                            CANCELAR
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
