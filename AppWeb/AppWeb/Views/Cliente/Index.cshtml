@model IEnumerable<AppWeb.Models.Videojuego>

@{
    ViewData["Title"] = "Juegos Disponibles";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">TIENDA DE JUEGOS</h2>
        <hr class="flex-grow-1 ms-4 opacity-25" />
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success bg-success text-white border-0 animate__animated animate__fadeIn">
            <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
        </div>
    }

    <div class="row g-4 mt-2">
        @foreach (var juego in Model)
        {
            <div class="col-6 col-md-4 col-lg-3">
                <div class="game-card shadow h-100 d-flex flex-column">
                    <div class="position-relative">
                        <img src="@juego.imagen" class="game-img" alt="@juego.Titulo" />
                        <span class="badge-top position-absolute top-0 end-0 m-2">
                            +@juego.Edad
                        </span>
                    </div>

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title" title="@juego.Titulo">@juego.Titulo</h5>
                        <div class="mt-auto pt-3">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="price">$@juego.Precio</span>
                            </div>
                            <a asp-action="ConfirmarCompra" asp-route-id="@juego.Id" class="btn btn-accent w-100 fw-bold">
                                <i class="fas fa-shopping-cart me-2"></i>ADQUIRIR
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="mt-5 d-flex justify-content-center">
        <nav aria-label="Navegación de páginas">
            <ul class="pagination pagination-sm">
                @for (int i = 1; i <= ViewBag.TotalPaginas; i++)
                {
                    <li class="page-item @(i == ViewBag.PaginaActual ? "active" : "")">
                        <a href="?pagina=@i" class="page-link @(i == ViewBag.PaginaActual ? "bg-info border-info" : "bg-dark text-muted border-secondary")">@i</a>
                    </li>
                }
            </ul>
        </nav>
    </div>
</div>