@model AppWeb.Models.Categoria

@{
    ViewData["Title"] = "Eliminar Categoría";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="glass-panel animate-in">
                <div class="mb-4">
                    <i class="fas fa-exclamation-triangle text-danger" style="font-size: 4rem;"></i>
                </div>
                <h2 class="mb-3 text-white">¿ELIMINAR CATEGORÍA?</h2>
                <p class="text-muted mb-4">
                    Estás a punto de eliminar la categoría <strong class="text-info">"@Model.categoria.ToUpper()"</strong>. 
                    Esta acción no se puede deshacer.
                </p>
                
                <form asp-action="Delete">
                    <input type="hidden" asp-for="idcategoria" />
                    <div class="d-flex gap-3">
                        <button type="submit" class="btn btn-steam-danger w-100 fw-bold py-2">
                            <i class="fas fa-trash me-2"></i>CONFIRMAR ELIMINACIÓN
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary w-100 fw-bold py-2">
                            CANCELAR
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
