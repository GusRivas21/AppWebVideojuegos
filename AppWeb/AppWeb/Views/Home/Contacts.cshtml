@{
    ViewData["Title"] = "Contacto";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="glass-panel shadow-lg animate__animated animate__fadeInUp">
                <div class="row">
                    <div class="col-md-6 mb-4 mb-md-0">
                        <h2 class="fw-bold text-info mb-4">¡HOLA, GAMER!</h2>
                        <p class="text-muted mb-4">¿Tienes dudas, sugerencias o simplemente quieres saludar? Estamos aquí para escucharte.</p>
                        
                        <div class="d-flex align-items-center mb-3">
                            <i class="fas fa-envelope text-info me-3 fa-lg"></i>
                            <div>
                                <span class="d-block small text-uppercase fw-bold opacity-50">Correo de Soporte</span>
                                <span class="text-white">soporte@gamestore.com</span>
                            </div>
                        </div>

                        <div class="d-flex align-items-center mb-3">
                            <i class="fas fa-map-marker-alt text-info me-3 fa-lg"></i>
                            <div>
                                <span class="d-block small text-uppercase fw-bold opacity-50">Ubicación</span>
                                <span class="text-white">Ciudad Gamer, Nivel 1-1</span>
                            </div>
                        </div>

                        <div class="mt-5">
                            <h6 class="text-uppercase small fw-bold text-muted mb-3">Síguenos</h6>
                            <div class="d-flex gap-3">
                                <a href="#" class="text-info"><i class="fab fa-discord fa-2xl"></i></a>
                                <a href="#" class="text-info"><i class="fab fa-twitter fa-2xl"></i></a>
                                <a href="#" class="text-info"><i class="fab fa-instagram fa-2xl"></i></a>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <form class="p-3 bg-dark bg-opacity-25 rounded border border-secondary border-opacity-25">
                            <div class="mb-3">
                                <label class="form-label small fw-bold text-info">NOMBRE</label>
                                <input type="text" class="form-control bg-dark border-secondary text-white" placeholder="Tu nombre..." />
                            </div>
                            <div class="mb-3">
                                <label class="form-label small fw-bold text-info">CORREO</label>
                                <input type="email" class="form-control bg-dark border-secondary text-white" placeholder="ejemplo@correo.com" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label small fw-bold text-info">MENSAJE</label>
                                <textarea class="form-control bg-dark border-secondary text-white" rows="4" placeholder="¿En qué podemos ayudarte?"></textarea>
                            </div>
                            <button type="button" class="btn btn-accent w-100 fw-bold py-2 mt-2">ENVIAR MENSAJE</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
