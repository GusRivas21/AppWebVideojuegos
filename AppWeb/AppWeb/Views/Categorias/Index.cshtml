@model IEnumerable<AppWeb.Models.Categoria>

@{
    ViewData["Title"] = "Categorías";
}

<div class="glass-panel mt-4 animate-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0"><i class="fas fa-tags me-2 text-info"></i>GESTIÓN DE CATEGORÍAS</h2>
        <a asp-action="Create" class="btn btn-accent fw-bold">
            <i class="fas fa-plus me-2"></i>NUEVA CATEGORÍA
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-steam">
            <thead>
                <tr>
                    <th>NOMBRE DE LA CATEGORÍA</th>
                    <th class="text-center" style="width: 200px;">ACCIONES</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold text-white">@item.categoria.ToUpper()</td>
                        <td class="text-center">
                            <div class="btn-group btn-group-sm">
                                <a asp-action="Edit" asp-route-id="@item.idcategoria" class="btn btn-steam-warning">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.idcategoria" class="btn btn-steam-danger">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
